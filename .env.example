CLIENT_URL=https://www.profixter.com
MONGO_URI=
JWT_SECRET=
JWT_RESET_SECRET=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_BILLING_PORTAL_CONFIGURATION_ID=
# Optional one-time save offer shown before self-serve membership cancellation.
# Configure with the Stripe "once" coupon ID for 30% off the next renewal.
STRIPE_RETENTION_COUPON_ID=
# Nightly Stripe-linked subscription reconciliation runs by default.
# Set to false only for controlled maintenance.
STRIPE_RECONCILIATION_ENABLED=true
# Optional Stripe price overrides. If omitted, backend resolves active Stripe
# prices by metadata, then falls back to the legacy built-in mapping.
STRIPE_PRICE_BASIC_MONTHLY=
STRIPE_PRICE_PLUS_MONTHLY=
STRIPE_PRICE_PREMIUM_MONTHLY=
STRIPE_PRICE_ELITE_MONTHLY=
STRIPE_PRICE_BASIC_ANNUAL=
STRIPE_PRICE_PLUS_ANNUAL=
STRIPE_PRICE_PREMIUM_ANNUAL=
STRIPE_PRICE_ELITE_ANNUAL=
STRIPE_PRICE_ONE_TIME_HANDYMAN_VISIT=
MAIL_ADMIN=
# Optional additional inbox for public lead notifications.
LEADS_EMAIL=
MAIL_FROM=Profixter <no-reply@profixter.com>
MAIL_REPLY_TO=getfixter@gmail.com
MARKETING_FROM=
PUBLIC_API_URL=https://api.profixter.com
EMAIL_UNSUBSCRIBE_SECRET=
EMAIL_BATCH_SIZE=10
EMAIL_BATCH_DELAY_MS=300
AWS_SES_SMTP_HOST=email-smtp.us-east-1.amazonaws.com
AWS_SES_SMTP_PORT=587
AWS_SES_SMTP_USER=
AWS_SES_SMTP_PASS=
BOOKING_REMINDERS_ENABLED=true
# Delayed review emails run by default. Set false to pause without code changes.
BOOKING_REVIEW_REQUESTS_ENABLED=true
ONE_TIME_VISIT_ENABLED=true
ONE_TIME_VISIT_PRICE_CENTS=9900
ONE_TIME_VISIT_DURATION_MINUTES=90
ONE_TIME_VISIT_HOLD_MINUTES=30
ONE_TIME_VISIT_CANCELLATION_PHONE=631-599-1363
# Pipe-separated overrides; leave blank to use the built-in one-time visit lists.
ONE_TIME_VISIT_ALLOWED_SERVICES=
ONE_TIME_VISIT_EXCLUDED_SERVICES=
ONE_TIME_VISIT_PROMO_NOTE=
ONE_TIME_VISIT_HOLD_CLEANUP_ENABLED=true
ONE_TIME_VISIT_HOLD_CLEANUP_MS=300000
OPENAI_API_KEY=
HOME_SUPPORT_AI_MODEL=gpt-4o-mini
HOME_SUPPORT_AI_RETENTION_DAYS=30
HOME_SUPPORT_AI_MAX_UPLOAD_MB=15
# Existing GHL integrations. Do not use this token for AI Commander.
GHL_API_TOKEN=
GHL_LOCATION_ID=
# Internal admin-only GHL AI Commander. Set false for emergency shutdown.
AI_COMMANDER_GHL_ENABLED=true
AI_COMMANDER_OPENAI_MODEL=gpt-4o-mini
GHL_AI_COMMANDER_TOKEN=
# Legacy marketing automations are opt-in. Keep false unless intentionally enabled.
WEEKLY_NUDGE_ENABLED=false
CHATBOT_FOLLOWUPS_ENABLED=false
NURTURE_ENABLED=false
NURTURE_START_DATE=
# Reservation/customer cutover flags remain disabled until readiness passes.
ENABLE_RESERVATION_ENGINE=false
ENABLE_CUSTOMER_AVAILABILITY_PREVIEW=false
# Set true only after the production transaction probe exits successfully.
MONGO_TRANSACTIONS_VERIFIED=false
